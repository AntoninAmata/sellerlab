      "0": 0.0,
      "1": 0.75,
      "2": 0.79,
      "6": 0.95,
      "10+": 0.97
    }
  },
  "bornes_securite": {
    "description": "Le prix final est borné pour éviter les valeurs aberrantes.",
    "min": "max(0.40 * mediane_vinted, ...) si médiane dispo",
    "max": "ne pas dépasser le neuf-décoté (prix_neuf_ref * decote * matiere)"
  },
